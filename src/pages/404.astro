---
import BaseLayout from '@/layouts/BaseLayout.astro';
import config from '@/data/config.json';

const { company } = config;
const lang = 'tr' as const;
---

<BaseLayout
  lang={lang}
  title="404 — Sayfa Bulunamadı / Page Not Found"
  description="The page you are looking for does not exist."
  canonicalUrl=""
>
  <div
    class="flex min-h-screen flex-col items-center justify-center px-6 py-24 text-center"
    style="background-color: var(--brand-surface);"
  >
    <!-- Large 404 numeral -->
    <p
      class="font-heading select-none text-[9rem] font-semibold leading-none tracking-tight opacity-10 sm:text-[12rem]"
      style="color: var(--brand-primary);"
      aria-hidden="true"
    >
      404
    </p>

    <!-- Decorative accent line -->
    <div
      class="mt-6 h-1 w-16 rounded-full"
      style="background-color: var(--brand-accent);"
      aria-hidden="true"
    ></div>

    <!-- TR message -->
    <div class="mt-8 max-w-sm">
      <h1
        class="font-heading text-2xl font-semibold"
        style="color: var(--brand-primary);"
      >
        Sayfa Bulunamadı
      </h1>
      <p class="mt-3 text-sm leading-relaxed text-gray-500">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
      </p>
    </div>

    <!-- Divider -->
    <div class="my-8 flex items-center gap-4">
      <div class="h-px w-12 bg-gray-200"></div>
      <span class="text-xs font-medium tracking-widest text-gray-300">OR / VEYA</span>
      <div class="h-px w-12 bg-gray-200"></div>
    </div>

    <!-- EN message -->
    <div class="max-w-sm">
      <h2
        class="font-heading text-2xl font-semibold"
        style="color: var(--brand-primary);"
      >
        Page Not Found
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-gray-500">
        The page you're looking for may have been moved, deleted, or never existed.
      </p>
    </div>

    <!-- CTAs — link to both locales so any user can navigate home -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/tr"
        class="inline-flex items-center gap-2 rounded-full px-8 py-3 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-90"
        style="background-color: var(--brand-primary);"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 7.5H4M7 4l-3.5 3.5L7 11"/>
        </svg>
        Anasayfaya Dön
      </a>
      <a
        href="/en"
        class="inline-flex items-center gap-2 rounded-full border px-8 py-3 text-sm font-semibold transition-opacity hover:opacity-80"
        style="border-color: var(--brand-primary); color: var(--brand-primary);"
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 7.5H4M7 4l-3.5 3.5L7 11"/>
        </svg>
        Go to Homepage
      </a>
    </div>

    <!-- Company name footer line -->
    <p class="mt-16 text-xs text-gray-300">
      {company.reportYear} &mdash; {lang === 'tr' ? company.nameTR : company.name}
    </p>
  </div>
</BaseLayout>
