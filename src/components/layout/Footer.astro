---
import type { Locale } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';
import config from '@/data/config.json';
import downloads from '@/data/downloads.json';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { company, social } = config;

const companyName     = lang === 'tr' ? company.nameTR : company.name;
const featuredReport  = downloads.documents.find(d => d.featured);
const reportTitle     = featuredReport
  ? (lang === 'tr' ? featuredReport.titleTR : featuredReport.titleEN)
  : '';

const socialLinks = [
  { href: social.linkedin,  label: 'LinkedIn', icon: 'linkedin'  },
  { href: social.twitter,   label: 'Twitter',  icon: 'twitter'   },
  { href: social.instagram, label: 'Instagram',icon: 'instagram' },
].filter(s => s.href);
---

<footer class="border-t border-gray-100 bg-[var(--brand-surface)]">
  <div class="mx-auto max-w-screen-xl px-6 py-14">

    <!-- Top row: brand + PDF download -->
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">

      <!-- Brand block -->
      <div class="max-w-sm">
        <div class="flex items-center gap-2">
          <img
            src={company.logo}
            alt={companyName}
            width="28"
            height="28"
            class="h-7 w-auto"
            onerror="this.style.display='none'"
          />
          <span class="font-heading text-base font-semibold" style="color: var(--brand-primary);">
            {companyName}
          </span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-gray-500">
          {company.reportYear} {lang === 'tr' ? 'Faaliyet Raporu' : 'Annual Report'}
        </p>
        <address class="mt-4 not-italic text-sm leading-relaxed text-gray-500">
          {company.address}
          <br />
          <a href={`tel:${company.phone}`} class="hover:text-[var(--brand-primary)] transition-colors">
            {company.phone}
          </a>
        </address>
      </div>

      <!-- PDF download CTA -->
      {featuredReport && (
        <div class="flex flex-col items-start gap-3 sm:items-end">
          <p class="text-xs font-medium uppercase tracking-widest text-gray-400">
            {t('downloads.sectionTitle')}
          </p>
          <a
            href={featuredReport.file}
            download
            class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand-primary)] focus-visible:ring-offset-2"
            style="background-color: var(--brand-primary);"
          >
            <!-- Download icon -->
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 2v8M5 7l3 3 3-3"/>
              <path d="M2 12h12"/>
            </svg>
            {reportTitle}
            <span class="text-xs font-normal opacity-80">
              ({featuredReport.fileSizeMB} MB)
            </span>
          </a>
        </div>
      )}
    </div>

    <!-- Divider -->
    <div class="my-10 h-px bg-gray-200"></div>

    <!-- Bottom row: links + social + copyright -->
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">

      <!-- Useful links -->
      <nav aria-label={lang === 'tr' ? 'Alt menü' : 'Footer navigation'}>
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-gray-500">
          <li>
            <a href={company.websiteUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--brand-primary)] transition-colors">
              {lang === 'tr' ? 'Kurumsal Web Sitesi' : 'Corporate Website'}
            </a>
          </li>
          <li>
            <a href={company.investorRelationsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--brand-primary)] transition-colors">
              {lang === 'tr' ? 'Yatırımcı İlişkileri' : 'Investor Relations'}
            </a>
          </li>
        </ul>
      </nav>

      <!-- Social links -->
      {socialLinks.length > 0 && (
        <div class="flex items-center gap-3">
          {socialLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="flex h-8 w-8 items-center justify-center rounded-full border border-gray-200 text-gray-500 transition-colors hover:border-[var(--brand-primary)] hover:text-[var(--brand-primary)]"
            >
              {icon === 'linkedin' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              )}
              {icon === 'twitter' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              )}
              {icon === 'instagram' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
                </svg>
              )}
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Disclaimer + copyright -->
    <div class="mt-8 text-xs leading-relaxed text-gray-400">
      <p>{t('footer.disclaimer')}</p>
      <p class="mt-1">
        © {company.reportYear} {companyName}. {t('footer.allRights')}
      </p>
    </div>
  </div>
</footer>
