---
import type { Locale } from '@/utils/i18n';
import ExecutiveCard from '@/components/content/ExecutiveCard.astro';
import messages from '@/data/messages.json';

interface Props { lang: Locale; }
const { lang } = Astro.props;

const eyebrow = lang === 'tr' ? 'Mesajlar'            : 'Messages';
const title   = lang === 'tr' ? 'Yönetimden Mesajlar' : 'From Our Leadership';
const subtitle= lang === 'tr'
  ? 'Yönetim Kurulu Başkanımız ve Genel Müdürümüzün 2024 yılına ilişkin değerlendirmeleri.'
  : 'Reflections on 2024 from our Chairman and Chief Executive Officer.';

// Pre-process outside template so Astro doesn't need fragments in map
const processed = messages.messages.map((msg, i) => ({
  index: i,
  name:       lang === 'tr' ? msg.nameTR      : msg.nameEN,
  role:       lang === 'tr' ? msg.titleTR     : msg.titleEN,
  photo:      msg.photo,
  pullQuote:  lang === 'tr' ? msg.pullQuoteTR : msg.pullQuoteEN,
  paragraphs: (lang === 'tr' ? msg.messageTR  : msg.messageEN).split('\n\n').filter(Boolean),
}));
---

<div>

  <!-- Section heading — mirrors Fields of Activity display heading architecture -->
  <div class="mb-10 text-center">
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.22em]" style="color: var(--brand-accent);">
      {eyebrow}
    </p>
    <h2
      class="msg-heading font-heading text-4xl font-semibold leading-none sm:text-5xl lg:text-6xl"
      style="color: var(--brand-primary);"
    >
      {title}
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-gray-500">{subtitle}</p>
  </div>

  <div class="flex flex-col">
    {processed.map(msg => (
      <div class={msg.index > 0 ? 'mt-16 border-t border-gray-100 pt-16' : ''}>
        <ExecutiveCard
          name={msg.name}
          title={msg.role}
          photo={msg.photo}
          pullQuote={msg.pullQuote}
          index={msg.index}
          accent={msg.index % 2 === 0 ? 'var(--brand-accent)' : 'var(--brand-primary)'}
        >
          {msg.paragraphs.map(p => <p>{p}</p>)}
        </ExecutiveCard>
      </div>
    ))}
  </div>
</div>

<style>
  /*
   * Letter-spacing compression/expand — identical mechanic to .areas-heading
   * and .about-heading. Starts compressed, expands to tracking-tight once
   * the parent SectionWrapper's .reveal receives .is-visible from ScrollObserver.
   */
  .msg-heading {
    letter-spacing: -0.07em;
    transition: letter-spacing 1.1s cubic-bezier(0.2, 0.9, 0.3, 1) 0.15s;
  }

  :global(.reveal.is-visible) .msg-heading,
  :global(.reveal-stagger.is-visible) .msg-heading {
    letter-spacing: -0.025em;
  }
</style>
