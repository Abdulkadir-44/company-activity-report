---
/**
 * Board member card for the /governance section.
 * Uses <details>/<summary> for zero-JS accessible expand/collapse of biography.
 */

interface Props {
  name: string;
  title: string;
  photo: string;
  appointmentYear: number;
  independent: boolean;
  committees: string[];
  bio: string;
  committeeLabels: Record<string, string>; // id → translated label
  lang?: 'tr' | 'en';
}

const {
  name,
  title,
  photo,
  appointmentYear,
  independent,
  committees,
  bio,
  committeeLabels,
  lang = 'tr',
} = Astro.props;

const readBio  = lang === 'tr' ? 'Biyografiyi Oku'  : 'Read Biography';
const hideBio  = lang === 'tr' ? 'Biyografiyi Gizle': 'Hide Biography';
const indLabel = lang === 'tr' ? 'Bağımsız Üye'     : 'Independent Member';
const sinceLabel = lang === 'tr' ? 'den beri'        : 'since';
---

<article class="group overflow-hidden rounded-2xl bg-white ring-1 ring-gray-100 transition-shadow duration-300 hover:shadow-md">
  <!-- Photo -->
  <div class="relative overflow-hidden bg-gray-50" style="height: 200px;">
    <img
      src={photo}
      alt={name}
      width="240"
      height="200"
      loading="lazy"
      class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
      onerror="this.onerror=null;this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22240%22 height=%22200%22 viewBox=%220 0 240 200%22%3E%3Crect width=%22240%22 height=%22200%22 fill=%22%23f1f5f9%22/%3E%3Ccircle cx=%22120%22 cy=%2272%22 r=%2236%22 fill=%22%23cbd5e1%22/%3E%3Cellipse cx=%22120%22 cy=%22168%22 rx=%2272%22 ry=%2248%22 fill=%22%23cbd5e1%22/%3E%3C/svg%3E'"
    />
    {independent && (
      <span
        class="absolute right-3 top-3 rounded-full px-2.5 py-1 text-xs font-semibold text-white shadow-sm"
        style="background-color: var(--brand-accent);"
      >
        {indLabel}
      </span>
    )}
  </div>

  <!-- Info -->
  <div class="p-5">
    <p class="font-heading text-base font-semibold text-gray-900 leading-snug">{name}</p>
    <p class="mt-0.5 text-sm text-gray-500">{title}</p>
    <p class="mt-1 text-xs text-gray-400">
      {appointmentYear} {sinceLabel}
    </p>

    <!-- Committee badges -->
    {committees.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {committees.map((id) => (
          <span
            key={id}
            class="rounded-full px-2.5 py-0.5 text-xs font-medium"
            style="background-color: color-mix(in srgb, var(--brand-primary) 8%, transparent); color: var(--brand-primary);"
          >
            {committeeLabels[id] ?? id}
          </span>
        ))}
      </div>
    )}

    <!-- Expandable bio (zero-JS via <details>) -->
    {bio && (
      <details class="mt-4 group/details">
        <summary
          class="flex cursor-pointer list-none items-center gap-1.5 text-xs font-semibold transition-colors hover:opacity-80 focus-visible:outline-none"
          style="color: var(--brand-primary);"
        >
          <!-- Chevron icon — rotates when open -->
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="transition-transform duration-200 group-open/details:rotate-180"
            aria-hidden="true"
          >
            <path d="M3 5l4 4 4-4"/>
          </svg>
          <span class="group-open/details:hidden">{readBio}</span>
          <span class="hidden group-open/details:inline">{hideBio}</span>
        </summary>
        <p class="mt-3 text-sm leading-relaxed text-gray-600">{bio}</p>
      </details>
    )}
  </div>
</article>
