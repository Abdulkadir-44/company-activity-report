---
/**
 * ESG target-vs-actual progress bar.
 * The fill animates its width from 0 → pct% when ScrollObserver adds .is-visible.
 * Receives raw values; displays a labelled track with percentage fill.
 */

interface Props {
  label: string;
  actual: number;
  target: number;
  unit?: string;
  targetYear?: number;
  lang?: 'tr' | 'en';
}

const { label, actual, target, unit = '', targetYear, lang = 'tr' } = Astro.props;

const pct     = Math.min(Math.round((actual / target) * 100), 100);
const reached = pct >= 100;

const actualStr = `${actual.toLocaleString(lang === 'tr' ? 'tr-TR' : 'en-US')}${unit}`;
const targetStr = `${target.toLocaleString(lang === 'tr' ? 'tr-TR' : 'en-US')}${unit}`;
---

<div class="space-y-2">
  <!-- Label row -->
  <div class="flex items-center justify-between gap-4">
    <span class="text-sm font-medium text-gray-700">{label}</span>
    <div class="flex shrink-0 items-center gap-2 text-xs text-gray-400">
      <span class="font-semibold" style="color: var(--brand-primary);">{actualStr}</span>
      <span>/</span>
      <span>
        {targetStr}
        {targetYear && <span class="ml-1">({targetYear})</span>}
      </span>
    </div>
  </div>

  <!-- Track -->
  <div
    class="relative h-2 w-full overflow-hidden rounded-full bg-gray-100"
    role="progressbar"
    aria-valuenow={pct}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={`${label}: ${pct}%`}
  >
    <!-- Fill — ScrollObserver adds .is-visible, triggering the CSS transition -->
    <div
      data-reveal
      class="progress-fill h-full rounded-full"
      style={`--pct: ${pct}%; background-color: ${reached ? 'var(--brand-accent)' : 'var(--brand-primary)'};`}
    ></div>
  </div>

  <!-- Percentage -->
  <p class="text-right text-xs font-medium" style="color: var(--brand-primary);">
    {pct}%{reached ? (lang === 'tr' ? ' ✓ Hedefe ulaşıldı' : ' ✓ Target reached') : ''}
  </p>
</div>
