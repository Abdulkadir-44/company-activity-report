---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}
const { eyebrow, title, subtitle, centered = false } = Astro.props;
---

<div class:list={['mb-12', centered && 'text-center']}>
  {eyebrow && (
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--brand-accent);">
      {eyebrow}
    </p>
  )}
  <h2
    class="font-heading text-3xl font-semibold leading-tight sm:text-4xl"
    style="color: var(--brand-primary);"
  >
    {title}
  </h2>
  {subtitle && (
    <p class:list={['mt-4 max-w-2xl text-base leading-relaxed text-gray-500', centered && 'mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
